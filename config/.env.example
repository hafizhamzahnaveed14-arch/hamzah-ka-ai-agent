# AlphaQuant AI environment template
# Copy to repo root as .env — never commit real secrets.

APP_ENV=development
APP_NAME=AlphaQuant AI
LOG_LEVEL=INFO
TRADING_MODE=paper
# Real money second switch — keep false until you intentionally go live
LIVE_TRADING_ENABLED=false

PRIMARY_EXCHANGE=mexc

CORS_ORIGINS=https://YOUR-SITE.netlify.app

# --- Database ---
# Local Docker Postgres OR Neon (recommended for always-on):
# Neon dashboard → Connection string → paste as DATABASE_URL (keep sslmode=require)
DATABASE_URL=
# Fallback local pieces (used only if DATABASE_URL empty)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=alphaquant
POSTGRES_PASSWORD=alphaquant_dev_only
POSTGRES_DB=alphaquant

# --- Redis (Upstash recommended in cloud) ---
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Always-on paper scanner ---
SCANNER_ENABLED=true
SCANNER_INTERVAL_SECONDS=300
SCANNER_ACCOUNT_EQUITY=10000
PAPER_WALLET_EQUITY=10000

# Risk — 200x + CROSS + ≤0.5% wallet init/stop budget
RISK_PER_TRADE_PCT=0.005
RISK_PER_TRADE_HARD_CAP_PCT=0.005
MAX_CONCURRENT_RISK_PCT=0.015
DAILY_LOSS_LIMIT_PCT=0.015
MIN_RISK_REWARD=2.0
MIN_CONFIDENCE=0.85
NEWS_BUFFER_MINUTES=30
TARGET_LEVERAGE=200
MAX_LEVERAGE=200
USE_FIXED_LEVERAGE=true
MARGIN_MODE=cross
LEVERAGE_SAFETY_BUFFER=3.0
STOP_LIQ_BUFFER_FRACTION=0.6
MAINTENANCE_MARGIN_RATE=0.004

# MEXC Futures — trade-only; withdrawals OFF; IP-whitelist your VPS IP
MEXC_API_KEY=
MEXC_API_SECRET=
MEXC_FUTURES_REST=https://api.mexc.com
MEXC_FUTURES_WS=wss://contract.mexc.com/edge

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_FUTURES_REST=https://fapi.binance.com
BINANCE_FUTURES_WS=wss://fstream.binance.com

# Notifications (phone alerts while you sleep)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

COINGECKO_API_KEY=
CRYPTO_PANIC_API_KEY=
CMC_API_KEY=
