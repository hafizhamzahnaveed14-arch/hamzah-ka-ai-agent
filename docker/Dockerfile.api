FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends build-essential \
  && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY shared ./shared
COPY data-layer ./data-layer
COPY indicators ./indicators
COPY strategies ./strategies
COPY risk-engine ./risk-engine
COPY api ./api
COPY database ./database
COPY services ./services
COPY backtesting ./backtesting
COPY ai-models ./ai-models
COPY config ./config
COPY scripts ./scripts

# Production deps only (no pytest/ruff) — faster, less OOM on Railway
RUN pip install --no-cache-dir -e .

ENV PYTHONUNBUFFERED=1
ENV TRADING_MODE=paper
ENV APP_ENV=production

EXPOSE 8000
CMD ["sh", "-c", "exec uvicorn alphaquant_api.main:app --host 0.0.0.0 --port ${PORT:-8000} --app-dir api"]
